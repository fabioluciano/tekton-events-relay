---
import { withBase, docsHref, REPO_URL } from '../lib/site';

interface Props {
  /** Render the docs search box in the nav. */
  search?: boolean;
}
const { search = false } = Astro.props;
const icon = withBase('/assets/icon.svg');
---

<header class="nav">
  <div class="nav-inner">
    <a class="brand" href={withBase('/')}>
      <img src={icon} alt="" />
      <span class="tname">Tekton Events Relay</span>
    </a>
    <nav class="nav-links">
      {search && (
        <div class="search">
          <input id="searchInput" type="search" placeholder="Search docs…" autocomplete="off" aria-label="Search documentation" />
          <kbd>/</kbd>
          <div class="search-results" id="searchResults" hidden></div>
        </div>
      )}
      <a href={docsHref('Quickstart')}>Quickstart</a>
      <a href={withBase('/docs')}>Docs</a>
      {!search && <a href={withBase('/#integrations')}>Integrations</a>}
      <button class="theme-btn" type="button" aria-label="Toggle color theme" onclick="terToggleTheme()">
        <svg class="ic-sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4.4"></circle><path d="M12 2.5v2.6M12 18.9v2.6M2.5 12h2.6M18.9 12h2.6M5 5l1.8 1.8M17.2 17.2 19 19M19 5l-1.8 1.8M6.8 17.2 5 19"></path></svg>
        <svg class="ic-moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.4 14.2A8.5 8.5 0 0 1 9.8 3.6a8.5 8.5 0 1 0 10.6 10.6Z"></path></svg>
      </button>
      <a class="gh" href={REPO_URL}>
        <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
        GitHub
      </a>
    </nav>
  </div>
</header>
