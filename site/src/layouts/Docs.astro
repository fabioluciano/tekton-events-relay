---
import Base from './Base.astro';
import Sidebar from '../components/Sidebar.astro';
import Toc from '../components/Toc.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  title: string;
  /** Slug of the page being viewed (for sidebar active state). */
  current: string;
  headings: Heading[];
}
const { title, current, headings } = Astro.props;
---

<Base title={title} search={true}>
  <div class="layout">
    <aside class="side">
      <Sidebar current={current} />
    </aside>
    <main class="doc" id="doc">
      <slot />
    </main>
    <Toc headings={headings} />
  </div>
</Base>

<style is:global>
  .layout {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 28px;
    display: grid;
    grid-template-columns: 248px minmax(0, 1fr) 190px;
    gap: 48px;
    align-items: start;
  }
  /* ---- sidebar ---- */
  .side {
    position: sticky;
    top: 62px;
    max-height: calc(100vh - 62px);
    overflow-y: auto;
    padding: 34px 0 60px;
    border-right: 1px solid var(--line);
  }
  .side h3 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 26px 0 10px;
    font-weight: 500;
  }
  .side h3:first-child {
    margin-top: 0;
  }
  .side ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .side a {
    display: block;
    color: var(--body);
    font-size: 14px;
    padding: 5px 12px;
    border-radius: 7px;
    border-left: 2px solid transparent;
  }
  .side a:hover {
    color: var(--ink);
    background: var(--hover-bg);
    text-decoration: none;
  }
  .side a.active {
    color: var(--cyan-bright);
    background: rgba(70, 226, 234, 0.07);
    border-left-color: var(--cyan-bright);
    border-radius: 0 7px 7px 0;
  }
  .side > *:first-child {
    margin-top: 0;
  }

  /* ---- article ---- */
  .doc {
    padding: 40px 0 90px;
    min-height: 70vh;
  }
  .doc h1 {
    font-size: 36px;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 18px;
    line-height: 1.15;
  }
  .doc h2 {
    font-size: 25px;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 44px 0 14px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }
  .doc h3 {
    font-size: 19px;
    color: var(--ink);
    margin: 32px 0 10px;
  }
  .doc h4 {
    font-size: 16px;
    color: var(--ink);
    margin: 26px 0 8px;
  }
  .doc p,
  .doc li {
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--body);
  }
  .doc strong {
    color: var(--ink);
  }
  .doc a {
    color: var(--cyan-bright);
  }
  .doc hr {
    border: none;
    border-top: 1px solid var(--line);
    margin: 36px 0;
  }
  .doc blockquote {
    margin: 20px 0;
    padding: 14px 20px;
    border-left: 3px solid var(--cyan);
    background: rgba(22, 196, 216, 0.06);
    border-radius: 0 10px 10px 0;
  }
  .doc blockquote p {
    margin: 0;
  }
  .doc code {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--inline-fg);
    background: var(--inline-bg);
    padding: 1px 6px;
    border-radius: 5px;
  }
  .doc pre {
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    border-radius: 12px;
    padding: 18px 20px;
    overflow-x: auto;
    margin: 18px 0;
  }
  .doc pre code {
    background: none;
    padding: 0;
    color: #c4d6e2;
    font-size: 13px;
    line-height: 1.65;
  }
  .doc table {
    border-collapse: collapse;
    width: 100%;
    margin: 20px 0;
    font-size: 14px;
    display: block;
    overflow-x: auto;
  }
  .doc th {
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    text-align: left;
    padding: 10px 14px;
    background: var(--bg-deep);
    border-bottom: 1px solid var(--line);
  }
  .doc td {
    padding: 9px 14px;
    border-bottom: 1px solid var(--line-soft);
  }
  .doc img {
    max-width: 100%;
    border-radius: 10px;
  }
  .doc pre.mermaid {
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    border-radius: 12px;
    padding: 22px;
    margin: 18px 0;
    display: flex;
    justify-content: center;
  }
  .doc-footer {
    margin-top: 54px;
    padding-top: 20px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    font-size: 13.5px;
    color: var(--muted);
  }
  .doc-footer a {
    color: var(--muted);
  }
  .doc-footer a:hover {
    color: var(--cyan-bright);
  }

  /* ---- search (in top nav) ---- */
  .search {
    position: relative;
    width: 230px;
    min-width: 0;
  }
  .search input {
    width: 100%;
    font-family: var(--sans);
    font-size: 13.5px;
    color: var(--ink);
    background: var(--hover-bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 7px 12px;
    outline: none;
  }
  .search input:focus {
    border-color: rgba(70, 226, 234, 0.5);
  }
  .search input::placeholder {
    color: var(--muted);
  }
  .search kbd {
    position: absolute;
    right: 9px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 1px 6px;
    pointer-events: none;
  }
  .search input:focus + kbd {
    display: none;
  }
  .search-results {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: 360px;
    z-index: 60;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: 0 18px 50px -12px rgba(0, 0, 0, 0.5);
    max-height: 62vh;
    overflow-y: auto;
    padding: 6px;
  }
  .sr-item {
    display: block;
    padding: 9px 12px;
    border-radius: 8px;
  }
  .sr-item:hover {
    background: var(--hover-bg);
    text-decoration: none;
  }
  .sr-item .sr-t {
    display: block;
    color: var(--ink);
    font-size: 13.5px;
    font-weight: 600;
  }
  .sr-item .sr-s {
    display: block;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.5;
    margin-top: 2px;
  }
  .sr-item mark {
    background: rgba(70, 226, 234, 0.25);
    color: var(--cyan-bright);
    border-radius: 3px;
    padding: 0 1px;
  }
  .sr-empty {
    padding: 10px 12px;
    font-size: 12.5px;
    color: var(--muted);
  }

  /* ---- floating toc ---- */
  .toc {
    position: sticky;
    top: 62px;
    max-height: calc(100vh - 62px);
    overflow-y: auto;
    padding: 46px 0 60px;
    font-size: 12.5px;
  }
  .toc-title {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 10px;
  }
  .toc a {
    display: block;
    color: var(--muted);
    padding: 3px 0 3px 12px;
    border-left: 2px solid var(--line);
    line-height: 1.45;
  }
  .toc a:hover {
    color: var(--ink);
    text-decoration: none;
  }
  .toc a.t-h3 {
    padding-left: 24px;
  }
  .toc a.active {
    color: var(--cyan-bright);
    border-left-color: var(--cyan-bright);
  }

  /* ---- prev / next ---- */
  .pn {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 48px;
  }
  .pn a {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 13px 18px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .pn a:hover {
    border-color: rgba(70, 226, 234, 0.4);
    text-decoration: none;
  }
  .pn .lbl {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .pn .ttl {
    color: var(--ink);
    font-weight: 600;
    font-size: 15px;
  }
  .pn a.next {
    text-align: right;
    align-items: flex-end;
    grid-column: 2;
  }

  @media (max-width: 1200px) {
    .layout {
      max-width: 1240px;
      grid-template-columns: 248px minmax(0, 1fr);
      gap: 56px;
    }
    .toc {
      display: none;
    }
  }
  @media (max-width: 860px) {
    .layout {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .side {
      position: static;
      max-height: none;
      border-right: none;
      border-bottom: 1px solid var(--line);
      padding: 24px 0;
    }
    .search {
      width: 150px;
    }
    .search kbd {
      display: none;
    }
    .search-results {
      width: min(360px, calc(100vw - 40px));
    }
  }
</style>

<script>
  import mermaid from 'mermaid';

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

  /* ---------- mermaid diagrams (rendered client-side, self-hosted) ---------- */
  const diagrams = document.querySelectorAll<HTMLElement>('pre.mermaid');
  if (diagrams.length) {
    const light = document.documentElement.getAttribute('data-theme') === 'light';
    mermaid.initialize({
      startOnLoad: false,
      theme: light ? 'default' : 'dark',
      securityLevel: 'loose',
      fontFamily: 'JetBrains Mono, ui-monospace, monospace',
    });
    mermaid.run({ nodes: diagrams }).catch(() => {});
  }

  /* ---------- table of contents scroll-spy ---------- */
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('#toc a'));
  if (tocLinks.length) {
    const map = new Map<Element, HTMLAnchorElement>();
    for (const a of tocLinks) {
      const id = decodeURIComponent((a.getAttribute('href') || '').slice(1));
      const el = id && document.getElementById(id);
      if (el) map.set(el, a);
    }
    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            tocLinks.forEach((l) => l.classList.remove('active'));
            map.get(e.target)?.classList.add('active');
          }
        }
      },
      { rootMargin: '0px 0px -75% 0px', threshold: 0 }
    );
    map.forEach((_a, el) => obs.observe(el));
  }

  /* ---------- client-side search over the build-time index ---------- */
  const input = document.getElementById('searchInput') as HTMLInputElement | null;
  const box = document.getElementById('searchResults');
  if (input && box) {
    type Doc = { slug: string; title: string; text: string };
    let index: Doc[] | null = null;

    const esc = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!);

    async function load() {
      if (index) return index;
      try {
        const r = await fetch(`${BASE}/search.json`);
        index = r.ok ? await r.json() : [];
      } catch {
        index = [];
      }
      return index!;
    }

    function snippet(text: string, q: string) {
      const i = text.toLowerCase().indexOf(q);
      if (i < 0) return esc(text.slice(0, 130)) + '…';
      const start = Math.max(0, i - 45);
      const seg = text.slice(start, start + 130);
      const safe = esc(seg);
      const re = new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'ig');
      return (start ? '…' : '') + safe.replace(re, (m) => `<mark>${m}</mark>`) + '…';
    }

    async function run() {
      const q = input!.value.trim().toLowerCase();
      if (!q) {
        box!.hidden = true;
        box!.innerHTML = '';
        return;
      }
      const docs = await load();
      const hits = docs
        .filter((d) => d.title.toLowerCase().includes(q) || d.text.toLowerCase().includes(q))
        .slice(0, 8);
      box!.hidden = false;
      box!.innerHTML = hits.length
        ? hits
            .map(
              (d) =>
                `<a class="sr-item" href="${BASE}/docs/${d.slug}"><span class="sr-t">${esc(
                  d.title
                )}</span><span class="sr-s">${snippet(d.text, q)}</span></a>`
            )
            .join('')
        : '<div class="sr-empty">No results.</div>';
    }

    input.addEventListener('input', run);
    input.addEventListener('focus', () => {
      if (input.value.trim()) run();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== input) {
        e.preventDefault();
        input.focus();
      } else if (e.key === 'Escape') {
        box.hidden = true;
        input.blur();
      }
    });
    document.addEventListener('click', (e) => {
      if (!box.contains(e.target as Node) && e.target !== input) box.hidden = true;
    });
  }
</script>
